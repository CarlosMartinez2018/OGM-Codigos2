# =============================================================
# AcentoPartners Email Classifier (Codigos2) — Configuración
# Copiar a .env y completar. NUNCA commitear .env (esta en .gitignore).
# =============================================================

# --- App ---
DEBUG=true
LOG_LEVEL=INFO

# --- Microsoft Graph API (Outlook + SharePoint) ---
# Registrar app en https://portal.azure.com > App registrations.
# Permisos de aplicacion: Mail.Read + Sites.Read.All (admin consent).
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
OUTLOOK_MAILBOX=lender-insurance@acentopartners.com
OUTLOOK_POLL_INTERVAL=60

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# --- Clasificador LLM opcional (reglas primero; LLM apoya si esta encendido) ---
USE_LLM_CLASSIFIER=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=300

# --- SharePoint ---
SHAREPOINT_HOSTNAME=finesa.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/AndexInsurance

# --- Adjuntos locales (busqueda de PDFs por lender) ---
DOCUMENT_BASE_PATH=./documentos
